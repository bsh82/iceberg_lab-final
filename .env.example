# Local defaults. Copy to .env if you want Makefile/script convenience.
AWS_PROFILE=iceberg-lab
AWS_REGION=ap-northeast-2
S3_BUCKET=metacode-iceberg-lakehouse
S3_WAREHOUSE=s3://metacode-iceberg-lakehouse/warehouse
BRONZE_PATH=s3://metacode-iceberg-lakehouse/bronze/criteo_attribution_events
CHECKPOINT_PATH=s3://metacode-iceberg-lakehouse/checkpoints

K8S_NAMESPACE=criteo-lakehouse
KAFKA_BOOTSTRAP_SERVERS=kafka.criteo-lakehouse.svc.cluster.local:9092
KAFKA_TOPIC=criteo-attribution-events

ICEBERG_CATALOG=lakehouse
SILVER_DB=ad_attribution_silver
GOLD_DB=ad_attribution_gold
OPS_DB=ad_attribution_ops

SPARK_IMAGE=criteo-spark:local
AIRFLOW_IMAGE=criteo-airflow:local
PRODUCER_IMAGE=criteo-producer:local
SUPERSET_IMAGE=criteo-superset:local
